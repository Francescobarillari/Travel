# JWT
JWT_SECRET=inserisci-una-chiave-segreta-lunga-almeno-32-caratteri
JWT_EXPIRATION=36000000

# Database PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/my_project_db
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
